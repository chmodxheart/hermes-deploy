# Template for secrets/hermes.yaml.
#
# 1. Copy this file to secrets/hermes.yaml.
# 2. Fill every REPLACE_ME value.
# 3. Encrypt in place:
#      sops -e -i secrets/hermes.yaml
# 4. Commit the encrypted file (never the plaintext).

# Environment file for the hermes-agent systemd service / container.
#
# REPLACE_ME tokens in this block:
#   CUSTOM_API_KEY          → auth token for your OpenAI-compatible backend
#                              (copy from whatever self-hosted / managed LLM
#                              endpoint you're pointing CUSTOM_API_URL at)
#   CUSTOM_API_URL          → full base URL of that endpoint, no trailing slash
#                              (e.g. https://llm.samesies.gay/v1 — not a secret
#                              per se, but lives in this env file)
#   SUPERMEMORY_API_KEY     → https://supermemory.ai/ → dashboard → API keys
#   EXA_API_KEY             → https://exa.ai/ → dashboard → API keys
#   DISCORD_BOT_TOKEN       → https://discord.com/developers/applications →
#                              your app → Bot → Reset Token
#   API_SERVER_KEY          → self-issued bearer for hermes's own HTTP API.
#                              Generate: openssl rand -hex 32
#   DISCORD_ALLOWED_USERS   → not a secret — comma-separated Discord user IDs
#                              authorized to DM the bot (get via right-click
#                              → "Copy User ID" in Discord with dev-mode on)
#   DISCORD_HOME_CHANNEL    → not a secret — the channel ID hermes posts
#                              status/home messages to (same copy-ID flow)
hermes_env: |
    CUSTOM_API_KEY=REPLACE_ME
    CUSTOM_API_URL=REPLACE_ME
    SUPERMEMORY_API_KEY=REPLACE_ME
    EXA_API_KEY=REPLACE_ME
    DISCORD_BOT_TOKEN=REPLACE_ME
    API_SERVER_KEY=REPLACE_ME
    DISCORD_ALLOWED_USERS=REPLACE_ME
    DISCORD_HOME_CHANNEL=REPLACE_ME

# JSON blob consumed by hermes-agent for any auth config that isn't a flat
# env var (provider-specific shapes, OAuth redirects, etc.). Keep as `{}` if
# you have nothing provider-specific to configure — hermes-agent tolerates
# the empty object.
hermes_auth_json: |
  {}
