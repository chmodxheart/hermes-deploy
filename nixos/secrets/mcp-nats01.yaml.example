# Template for secrets/mcp-nats01.yaml.
#
# 1. Copy this file to secrets/mcp-nats01.yaml.
# 2. Fill every REPLACE_ME value.
# 3. Encrypt in place:
#      sops -e -i secrets/mcp-nats01.yaml
# 4. Commit the encrypted file (never the plaintext).
#
# See 01-RESEARCH.md §Pattern 1 (NATS server config) + §Pitfalls P9
# (cert bootstrap ordering) for where these secrets are consumed.

# step-ca root certificate (PEM). REUSE the same bytes you paste into
# secrets/mcp-audit.yaml `step_ca_root_cert`. All three NATS hosts AND the
# audit host share this single root so cert chains validate uniformly.
# Wired via sops.secrets."step-ca-root".path = "/run/secrets/step-ca-root";
# NATS + Vector clients verify server cert chain against this.
step_ca_root_cert: |
    -----BEGIN CERTIFICATE-----
    REPLACE_ME_STEP_CA_ROOT_PEM
    -----END CERTIFICATE-----

# NATS server cert + key are issued at runtime by the nats-server-cert.service
# oneshot (see RESEARCH §Pattern 2 lines 418-437). These entries are empty
# placeholders — the bootstrap writes them into /run/secrets.mut/ on first boot.
# Keep the REPLACE_ME strings as-is; the cert-bootstrap oneshot overwrites via
# `step ca certificate` output. No manual generation needed.
nats_server_cert: REPLACE_ME_POPULATED_AT_BOOTSTRAP
nats_server_key: REPLACE_ME_POPULATED_AT_BOOTSTRAP

# Vector client cert + key — same story; cert-bootstrap oneshot writes them.
# Leave as-is; populated at first boot.
vector_client_cert: REPLACE_ME_POPULATED_AT_BOOTSTRAP
vector_client_key: REPLACE_ME_POPULATED_AT_BOOTSTRAP

# NATS user creds (.creds blob) for Vector on this host. Generated one-time
# on your workstation via nsc after the NATS cluster is healthy — see
# docs/ops/nats-bring-up.md in Plan 01-09. Commands:
#   nsc add user -a AUDIT vector-mcp-nats01 \
#     --allow-pub 'audit.otlp.traces.mcp-nats01,audit.journal.mcp-nats01'
#   nsc generate creds -a AUDIT -n vector-mcp-nats01
# Paste the full creds output (JWT + NKEY SEED blocks with BEGIN/END markers) below.
#
# Per-user scope: this user can ONLY publish audit.otlp.traces.mcp-nats01 and
# audit.journal.mcp-nats01 (ACLs enforced server-side by the AUDIT account JWT).
nats_client_creds: |
    -----BEGIN NATS USER JWT-----
    REPLACE_ME_NATS_USER_JWT_for_mcp-nats01
    ------END NATS USER JWT------
    -----BEGIN USER NKEY SEED-----
    REPLACE_ME_NATS_USER_NKEY_SEED_for_mcp-nats01
    ------END USER NKEY SEED------
