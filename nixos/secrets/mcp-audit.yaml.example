# Template for secrets/mcp-audit.yaml.
#
# 1. Copy this file to secrets/mcp-audit.yaml.
# 2. Fill every REPLACE_ME value.
# 3. Encrypt in place:
#      sops -e -i secrets/mcp-audit.yaml
# 4. Commit the encrypted file (never the plaintext).
#
# See .planning/phases/01-audit-substrate/01-CONTEXT.md D-05 for the
# MinIO-on-minio.samesies.gay bucket + access-key story.
# See 01-RESEARCH.md §Pattern 4 for the Langfuse env-var contract.
#
# Generation rules of thumb:
#   strong random, URL-safe : pwgen -s 32 1     (use for any value that ends
#                                                up inside a URI — DB/Redis pw)
#   strong random, any shape: openssl rand -base64 32
#   exact 64-hex string     : openssl rand -hex 32

# Environment file for the langfuse-web container (oci-containers).
# Mandatory env vars per langfuse.com/self-hosting/deployment/infrastructure/containers.
# S3/MinIO points at the existing external bucket, not an in-LXC MinIO (D-05).
#
# REPLACE_ME tokens in this block:
#   REPLACE_ME_PG_PASSWORD            → REUSE value of top-level `postgres_password` below
#   REPLACE_ME_NEXTAUTH_SECRET        → openssl rand -base64 32
#   REPLACE_ME_SALT                   → openssl rand -base64 32   (MUST match langfuse_worker_env)
#   REPLACE_ME_ENCRYPTION_KEY_64_HEX  → openssl rand -hex 32      (exactly 64 hex chars; MUST match langfuse_worker_env)
#   REPLACE_ME_CLICKHOUSE_PASSWORD    → REUSE value of top-level `clickhouse_password` below
#   REPLACE_ME_REDIS_PASSWORD         → REUSE value of top-level `redis_password` below
#   REPLACE_ME_MINIO_ACCESS_KEY       → existing minio.samesies.gay access key, scoped to `langfuse` bucket only
#   REPLACE_ME_MINIO_SECRET_KEY       → paired MinIO secret key (from the same user)
langfuse_web_env: |
    DATABASE_URL=postgresql://langfuse:REPLACE_ME_PG_PASSWORD@127.0.0.1:5432/langfuse
    NEXTAUTH_URL=http://localhost:3000
    NEXTAUTH_SECRET=REPLACE_ME_NEXTAUTH_SECRET
    SALT=REPLACE_ME_SALT
    ENCRYPTION_KEY=REPLACE_ME_ENCRYPTION_KEY_64_HEX
    CLICKHOUSE_URL=http://127.0.0.1:8123
    CLICKHOUSE_MIGRATION_URL=clickhouse://127.0.0.1:9000
    CLICKHOUSE_USER=default
    CLICKHOUSE_PASSWORD=REPLACE_ME_CLICKHOUSE_PASSWORD
    REDIS_CONNECTION_STRING=redis://:REPLACE_ME_REDIS_PASSWORD@127.0.0.1:6379/0
    LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
    LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1
    LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=REPLACE_ME_MINIO_ACCESS_KEY
    LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=REPLACE_ME_MINIO_SECRET_KEY
    LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=https://minio.samesies.gay
    LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
    LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/

# Same backends as langfuse_web_env. Every overlapping token MUST match the
# web-side value verbatim — data encrypted/salted on web must decrypt on
# worker, and they share the same DB/Redis/ClickHouse/S3. NEXTAUTH_* is
# web-only, so this block omits it.
#
# REPLACE_ME tokens: every one of these is a REUSE from langfuse_web_env above.
langfuse_worker_env: |
    DATABASE_URL=postgresql://langfuse:REPLACE_ME_PG_PASSWORD@127.0.0.1:5432/langfuse
    SALT=REPLACE_ME_SALT
    ENCRYPTION_KEY=REPLACE_ME_ENCRYPTION_KEY_64_HEX
    CLICKHOUSE_URL=http://127.0.0.1:8123
    CLICKHOUSE_MIGRATION_URL=clickhouse://127.0.0.1:9000
    CLICKHOUSE_USER=default
    CLICKHOUSE_PASSWORD=REPLACE_ME_CLICKHOUSE_PASSWORD
    REDIS_CONNECTION_STRING=redis://:REPLACE_ME_REDIS_PASSWORD@127.0.0.1:6379/0
    LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
    LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1
    LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=REPLACE_ME_MINIO_ACCESS_KEY
    LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=REPLACE_ME_MINIO_SECRET_KEY
    LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=https://minio.samesies.gay
    LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
    LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/

# Environment file for the langfuse-nats-ingest Python service (D-08).
# Basic-auth header pk:sk base64'd at runtime by langfuse-nats-ingest.py.
#
# REPLACE_ME tokens: these API keys don't exist until Langfuse is running.
# Stub any non-empty string now, then after first boot of langfuse-web:
#   1. Open https://mcp-audit.samesies.gay/ , sign up, create a project.
#   2. Project Settings → API Keys → Create new API keys.
#   3. Paste the pk-lf-... and sk-lf-... values here.
#   4. sops -e -i secrets/mcp-audit.yaml && terraform apply
langfuse_ingest_env: |
    LANGFUSE_PUBLIC_KEY=REPLACE_ME_LANGFUSE_PUBLIC_KEY
    LANGFUSE_SECRET_KEY=REPLACE_ME_LANGFUSE_SECRET_KEY

# Database bootstrap (used by services.postgresql.initialScript / initial
# ClickHouse user). Scoped to localhost-only since both services bind 127.0.0.1.

# Generate: pwgen -s 32 1   (alphanumeric — safe inside the DATABASE_URL above)
postgres_password: REPLACE_ME_PG_PASSWORD

# Generate: pwgen -s 32 1
clickhouse_password: REPLACE_ME_CLICKHOUSE_PASSWORD

# Generate: pwgen -s 32 1   (alphanumeric — safe inside the REDIS_CONNECTION_STRING above)
# Redis localhost-only but password still set — layer at zero cost (see RESEARCH Open Q 3).
redis_password: REPLACE_ME_REDIS_PASSWORD

# step-ca co-located on this host

# Intermediate CA key password — cannot boot step-ca without it.
# Generate: openssl rand -base64 32
step_ca_intermediate_pw: REPLACE_ME_STEP_CA_INTERMEDIATE_PW

# PEM-formatted step-ca root cert. step-ca mints this on first `step ca init`
# after deploy — don't pre-generate. Stub with any non-empty placeholder for
# the first deploy; then:
#   ssh root@mcp-audit.samesies.gay cat /etc/step-ca/certs/root_ca.crt
# paste the real PEM here, sops -e -i, redeploy. Distributed to every client
# LXC via their own secrets/mcp-nats-*.yaml entry of the same name.
step_ca_root_cert: |
    -----BEGIN CERTIFICATE-----
    REPLACE_ME_STEP_CA_ROOT_PEM
    -----END CERTIFICATE-----

# NATS admin credentials bundle (nsc output; see docs/ops/nats-bring-up.md
# in Plan 01-09 for the one-time nsc bootstrap). Used by langfuse-nats-ingest
# as a subscribe-only account consumer on audit.otlp.>.
#
# Generated one-time on your workstation after the NATS cluster is healthy:
#   nsc add user -a AUDIT langfuse-ingest --allow-sub 'audit.otlp.>'
#   nsc generate creds -a AUDIT -n langfuse-ingest
# Paste the full creds output (JWT + NKEY SEED blocks with BEGIN/END markers) below.
nats_ingest_creds: |
    -----BEGIN NATS USER JWT-----
    REPLACE_ME_NATS_INGEST_USER_JWT
    ------END NATS USER JWT------
    ************************* IMPORTANT *************************
    NKEY Seed printed below can be used to sign and prove identity.
    NKEYs are sensitive and should be treated as secrets.
    -----BEGIN USER NKEY SEED-----
    REPLACE_ME_NATS_INGEST_USER_NKEY_SEED
    ------END USER NKEY SEED------
    *************************************************************
