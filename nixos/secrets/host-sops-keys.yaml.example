# Template for secrets/host-sops-keys.yaml.
#
# This file holds dedicated age private keys — one per audit-plane LXC.
# It is encrypted with the workstation age key ONLY (see .sops.yaml
# creation_rules), so hosts cannot decrypt each other's identities.
#
# DO NOT populate this file by hand. Use:
#
#   ./scripts/add-host.sh <hostname>
#
# which generates a keypair, publishes the pubkey into .sops.yaml, and
# injects the private key here under the host's name.
#
# Consumed by scripts/bootstrap-host.sh during the first nixos-rebuild
# of each fresh LXC: it decrypts the matching key and writes it to
# /var/lib/sops-nix/key.txt on the target before activation.

mcp-audit: |
  # AGE-SECRET-KEY-1...  (populated by scripts/add-host.sh)
mcp-nats-1: |
  # AGE-SECRET-KEY-1...
mcp-nats-2: |
  # AGE-SECRET-KEY-1...
mcp-nats-3: |
  # AGE-SECRET-KEY-1...
