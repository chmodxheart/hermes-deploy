# Template for secrets/nats-operator.yaml.
#
# 1. Copy this file to secrets/nats-operator.yaml.
# 2. Fill every REPLACE_ME value FROM the nsc output produced during
#    the one-time bootstrap (docs/ops/nats-bring-up.md — delivered in Plan 01-09).
# 3. Encrypt in place:
#      sops -e -i secrets/nats-operator.yaml
# 4. Commit the encrypted file (never the plaintext).
#
# This file is decrypted by all three mcp-nats* LXCs (shared recipient
# block in .sops.yaml). Evelyn is admin-recovery recipient.
#
# Standardized auth model:
# - one shared AUDIT account for application traffic
# - per-host publisher users under AUDIT (stored in each host's own secret file)
# - one admin user under AUDIT for operator tasks
# - cluster/node identity stays separate from application auth
#
# See .planning/phases/01-audit-substrate/01-RESEARCH.md §Pitfalls P8 for
# the one-time nsc bootstrap ("NSC_HOME=$(mktemp -d)" for bootstrap,
# capture outputs, commit to sops, then Nix build only reads them).
#
# --------------------------------------------------------------------------
# EVERY value in this file is produced by `nsc` — none are hand-generated.
# Run the bootstrap sequence ONCE on your workstation (destroys NSC_HOME on
# exit) and collect the outputs:
#
#   export NSC_HOME=$(mktemp -d)
#   nsc add operator -n mcp-audit-cluster --sys
#   nsc edit operator --service-url nats://mcp-nats01.samesies.gay:4222
#   nsc add account -n AUDIT
#   nsc add user  -a AUDIT admin
#   # per-host publisher users are created separately and their creds live in:
#   #   secrets/mcp-nats01.yaml
#   #   secrets/mcp-nats02.yaml
#   #   secrets/mcp-nats03.yaml
#   # then extract each field below per the inline commands.
# --------------------------------------------------------------------------
#
# nsc seed/key prefix legend (SEEDS all start with S — the SECOND character
# encodes the role; PUBLIC KEYS drop the S):
#   SO... operator seed      O... operator public
#   SA... account seed       A... account public
#   SU... user seed          U... user public
# --------------------------------------------------------------------------

# Operator JWT — the NATS server's `operator:` setting reads THIS path.
# Despite the historical "seed" suffix in older docs, this slot holds the
# JWT (a long eyJ...-prefixed base64 string), NOT the SO... operator seed.
# Extract:
#   nsc env --operator mcp-audit-cluster
#   nsc describe operator --raw
nats_operator_jwt: REPLACE_ME_NATS_OPERATOR_JWT

# System account public key (embedded in nats.conf `system_account`).
# Extract:  nsc describe account -n SYS --field sub
# (prints the A... pubkey on a single line. DON'T add --raw — that dumps the
# whole JWT instead of the field.)
nats_system_account_public_key: REPLACE_ME_NATS_SYSTEM_ACCOUNT_PUB

# Account JWT blob(s). Loaded by modules/nats-accounts.nix into
# /var/lib/nats/jwt/<name>.jwt for the NATS "full" resolver to index.
# The YAML key names must match `accountNames` in modules/nats-accounts.nix.
#
# Extract:  nsc describe account -n AUDIT --raw
# (the output IS the JWT — single long eyJ... base64 string)
nats_account_audit_jwt: REPLACE_ME_ACCOUNT_AUDIT_JWT

# Admin-user creds (stream-admin scope) — used by the one-time stream-create
# systemd oneshot (see RESEARCH §Code Examples Common Operation 3).
# Extract:  nsc generate creds -a AUDIT -n admin
# (outputs the full JWT + NKEY SEED block with BEGIN/END markers — paste
# verbatim below, replacing the whole placeholder block including markers)
nats_admin_creds: |
    -----BEGIN NATS USER JWT-----
    REPLACE_ME_ADMIN_USER_JWT
    ------END NATS USER JWT------
    -----BEGIN USER NKEY SEED-----
    REPLACE_ME_ADMIN_USER_NKEY_SEED
    ------END USER NKEY SEED------
