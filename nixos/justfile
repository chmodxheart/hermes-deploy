set shell := ["fish", "-c"]
set dotenv-load := false

host := env_var_or_default("HOST", "hermes")

_default:
    @just --list --unsorted

# Evaluate the flake without building
check:
    nix flake check --no-build

# Build a host's toplevel derivation without activating
build HOST=host:
    nix build ".#nixosConfigurations.{{HOST}}.config.system.build.toplevel"

# Rebuild and switch on the current machine (run on the target host)
switch HOST=host:
    sudo nixos-rebuild switch --flake ".#{{HOST}}"

# Dry-run: show what would change
dry-run HOST=host:
    sudo nixos-rebuild dry-activate --flake ".#{{HOST}}"

# Deploy to a remote host over SSH (needs wheel + passwordless sudo)
deploy HOST=host TARGET="":
    #!/usr/bin/env fish
    set -l target "{{TARGET}}"
    if test -z "$target"
        ../scripts/bootstrap-host.sh "{{HOST}}"
        exit $status
    end

    if string match -qr '^{{HOST}}(\..+)?$' -- "$target"
        if string match -q '*.*' -- "$target"
            set -l parts (string split '.' -- "$target")
            set -l domain (string join '.' $parts[2..-1])
            env MCP_DOMAIN="$domain" ../scripts/bootstrap-host.sh "{{HOST}}"
        else
            ../scripts/bootstrap-host.sh "{{HOST}}"
        end
        exit $status
    end

    nixos-rebuild switch --flake ".#{{HOST}}" \
        --target-host "eve@$target" --use-remote-sudo --fast

# Format every .nix file in the tree
fmt:
    nix fmt

# Update all flake inputs
update:
    nix flake update

# Edit the encrypted hermes secrets file
edit-secrets:
    sops secrets/hermes.yaml

# Derive the age public recipient from the current user's sops key
show-recipient:
    age-keygen -y ~/.config/sops/age/keys.txt

# Verify system.autoUpgrade.flake URL matches git origin remote
check-autoupgrade:
    #!/usr/bin/env fish
    set -l configured (rg -oP 'flake = "github:\K[^/]+/[^?"]+' modules/common.nix | head -n 1)
    set -l remote (git -C .. remote get-url origin | sed -E 's|.*[:/]([^/:]+/[^/]+?)(\.git)?$|\1|')
    if test "$configured" = "$remote"
        echo "OK: autoUpgrade flake ($configured) matches origin remote"
    else
        echo "MISMATCH: autoUpgrade='$configured' but origin='$remote'"
        exit 1
    end
